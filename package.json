{
  "name": "gr55-control-room",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "bridge": "node scripts/gr55-bridge.mjs",
    "dev:full": "sh -c 'npm run bridge & bridge_pid=$!; trap \"kill $bridge_pid 2>/dev/null\" EXIT; npm run dev'",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "midi": "^2.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "usb": "^3.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
